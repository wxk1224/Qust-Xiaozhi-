page {
  background-color: #fff;
}

 .refresh-btn{
   width: 35rpx;
   height: 35rpx; 
   top: 6rpx;
 }
 
 .week-list{
   position: fixed;
   left: 0;
   width: 100%;
   height: 92rpx;
   display: flex;
   align-items: center;
   background: #F5F7F8;
   z-index: 1;
 }


 .now-month{
   width: 50rpx;
   display: flex;
   flex-direction: column;
   justify-content: center;
   align-items: center;
   font-size: 24rpx;
   color: #666666;
 }

 .week-item{
   width:calc((100% - 50rpx) /7 ) ;
   height: 100%;
   display: flex;
   flex-direction: column;
   align-items: center;
   justify-content: center;
 }

 .week-item.active {
  background:#1278ba;
  border-radius: 20rpx;
}


 .week-name{
   font-size: 24rpx;
   color: #444444;
 }

 .week-date{
   font-size: 20rpx;
   color:#a1a1a1;
 }

 .active .week-name,
.active .week-date {
  color: #fff;
}

 .course-content{
   width:100%;
   padding-top: 92rpx;
   display: flex;

 }
.course-nums{
  width: 50rpx;
  display: flex;
  align-items: center;
  flex-direction: column;
  justify-content: center;
  background: #f5f6f7; 
}
.course-num{
   height: 120rpx;  
   display: flex;
   align-items: center;
   justify-content: center;
   color: #999999;
   font-size: 24rpx;

}
.course-list {
  width: 100%;
  height: 100%;
  position: relative;
}

.course-item {
  position: absolute;
  width: calc((100% - 50rpx) / 7);
  padding: 2rpx;
}

.course-item__content {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #ffffff;
  text-align: center;
}

.switch-week__popup {
  padding: 30rpx;
}

.switch-week__title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 500;
}

.switch-week__list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 30rpx;
}

.switch-week__item {
  width: 20%;
  padding: 10rpx;
}

.switch-week__item-box {
  width: 100%;
  height: 100rpx;
  background-color: #eee;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
}

.switch-week__item-box.active {
  background-color: #1278ba;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.course-swpier {
  width: calc(100% - 50rpx);
  height: 1200rpx;
}