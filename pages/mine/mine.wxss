page{
  background-color: white;
  height: 100%;
}
.container{
  height: 70%;
  width: 100%;
  padding: 48rpx 20rpx;
}

.head{
  box-shadow: 0px 0px 24rpx -4rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  height: 350rpx;
  display: flex;
  align-items: center;
  padding: 14rpx 40rpx;
  border-radius: 40rpx;

}

.head image{
  height: 200rpx;
  width: 200rpx;

}
.name-area{
  margin-left: 40rpx;
  font-size: 40rpx;
}

.main{
  box-shadow: 0px 0px 24rpx -4rpx rgba(0, 0, 0, 0.1);
  width: 100%;
  height: 80%;
  margin-top: 30rpx;
  padding: 14rpx 40rpx;
  display: flex;
  justify-content:space-between;
  align-items: center;
  border-radius: 40rpx;

}