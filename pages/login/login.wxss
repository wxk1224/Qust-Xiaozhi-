.container{
  margin: 0;
  padding: 0;
  height: 100%;
  width: 100%;
  
  /* background-color: #1278ba; */
}

.logo_area{
  margin-top:0 rpx;
  padding: 0;
  width: 100%;
  height: 30%;
  display: flex;
  justify-content: center;
}

.input_area{
  padding: 50rpx;
  margin-top: 30rpx;
}

.text_area{
  position: relative;
}


.text_area #text_1{
  position: absolute;
  left: 30rpx; 
  top: -15rpx;  
  
}
.text_area #text_2{
  position: absolute;
  left: 30rpx;
  top:115rpx
}

.text_area .text {
  font-size: 30rpx;
  font-family:Verdana, Geneva, Tahoma, sans-serif;
  font-weight: 400;
  letter-spacing: 0.8rpx;
  line-height: 28rpx;
  color: #5fa8da;
  text-align: left;
  text-shadow:  0 0 4rpx #87b6cf;

  width: 165rpx;
  height: 30rpx;
  vertical-align: top;
  background-color:#f1f1f1 ;
}
.text_area .icon{
  height: 40rpx;
  width: 40rpx;
  margin-right: 20rpx ;
}

.input_item{
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  border: 1rpx solid #1278ba;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 0 8rpx inset #1278ba ;
 
}

.btn_area{
  padding: 30rpx;
  width: 100%;

}

.btn_area button{
  background-color: #1278ba;
  color: #f1f1f1;
  border-radius: 20rpx;
}

.info{
  text-align: center;
  font-size: 50rpx;
  font-weight: 400;
  letter-spacing: 0.8rpx;
  font-family:Georgia, 'Times New Roman', Times, serif;
  width: 100%;
  height: 70rpx;
  position: fixed;
  bottom: 50rpx;


}












